use_frameworks!

platform :ios, '15.0'

def qa_assistant_pods
  pod 'ABTastyQAssistant', :path => '../'
end

# Demo host application.
target 'ABTastyQAssistant_Example' do
  qa_assistant_pods
end

# SDK-only unit test bundle (no host application).
# Links the ABTastyQAssistant framework directly so the tests exercise the
# SDK classes in isolation, without running the Example app.
target 'ABTastyQAssistant_Tests' do
  qa_assistant_pods
end
